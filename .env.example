# Docker Compose 环境变量配置文件
# 复制此文件为 .env 并填写实际的值

# 腾讯云 COS 配置
COS_CLIENT_HOST=https://your-bucket.cos.your-region.myqcloud.com
COS_CLIENT_SECRET_ID=your-secret-id-here
COS_CLIENT_SECRET_KEY=your-secret-key-here
COS_CLIENT_REGION=cos.your-region
COS_CLIENT_BUCKET=your-bucket-name

# 数据库配置（如果需要覆盖默认值）
# SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/yu_picture?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
# SPRING_DATASOURCE_USERNAME=root
# SPRING_DATASOURCE_PASSWORD=lirong

# Redis 配置（如果需要覆盖默认值）
# SPRING_REDIS_HOST=redis
# SPRING_REDIS_PORT=6379
# SPRING_REDIS_PASSWORD=

# 应用配置
# SERVER_PORT=8123
